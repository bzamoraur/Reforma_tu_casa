{
  "name": "reforma-quest-madrid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reforma Quest Madrid — a low-cost, high-rigor educational web game about renovating a home in Madrid. MVP: isometric-lite, level-based adventure. All technical content is draft / pending expert review.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run src/tests/golden",
    "test:e2e": "playwright test",
    "content:lint": "tsx scripts/content-lint.ts",
    "audit:high": "npm audit --audit-level=high"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
